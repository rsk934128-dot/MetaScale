
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Imperial Bypass for the Master Governor
    function isMasterAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == 'rsk934128@gmail.com' || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN'));
    }

    function isAdmin() {
      return isMasterAdmin();
    }

    // System Configuration Rules (Top Priority for Heartbeat)
    match /system/{configId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if isAuthenticated(); 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['balance', 'role', 'trustScore']);
      allow write: if isAdmin();

      match /cards/{cardId} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /assets/{asset} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /notifications/{notif} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /payment_links/{link} { 
        allow read: if true;
        allow write: if isOwner(userId) || isAdmin() || !isAuthenticated();
      }
      match /watchlist/{item} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /linked_banks/{bank} { allow read, write: if isOwner(userId) || isAdmin(); }
    }

    // SMS Signals (Mobile Interception)
    match /sms_signals/{signalId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); 
      allow update, delete: if isAdmin();
    }

    match /payment_links/{linkId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if true;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.creatorId == request.auth.uid);
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated(); 
      allow write: if isAdmin();
    }

    match /ubil_events/{event} {
      allow read: if isAuthenticated();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /verification_docs/{doc} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    match /limit_requests/{request} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    match /inquiries/{inquiry} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    match /events/{event} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    match /civic/emergencies/active/{emergency} {
      allow read, write: if isAuthenticated();
    }
    
    match /readiness/{checkId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
