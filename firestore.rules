
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if isAuthenticated(); // Allow reading profile info for mesh visibility
      
      // Allow creation for self during registration
      allow create: if isOwner(userId);
      
      // Strict Update boundary: Users CANNOT change their own balance, role, or trustScore
      // 'plan' is allowed for self-upgrade in this environment
      allow update: if isOwner(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['balance', 'role', 'trustScore']);
      
      // Admin can update everything (e.g., via compliance panel)
      allow write: if isAdmin();

      match /cards/{cardId} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /assets/{asset} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /notifications/{notif} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /payment_links/{link} { 
        allow read: if true; // Allow public reading for checkout
        allow write: if isOwner(userId) || isAdmin() || !isAuthenticated(); // Allow public update for status sync
      }
      match /watchlist/{item} { allow read, write: if isOwner(userId) || isAdmin(); }
    }

    // Root Payment Links (Mandatory for public checkout)
    match /payment_links/{linkId} {
      allow read: if true; // Public checkout needs to read
      allow create: if isAuthenticated();
      allow update: if true; // Allow public update for simulation during checkout
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.creatorId == request.auth.uid);
    }

    // Payment Ledger (Global view allowed for authenticated users in prototype mesh)
    match /payments/{paymentId} {
      allow read: if isAuthenticated(); 
      allow write: if isAdmin(); // Only Admin (Server SDK / Cloud Functions) can write
    }

    // Unified Banking Intel Layer Events (Global view for mesh synchronization)
    match /ubil_events/{event} {
      allow read: if isAuthenticated() || isAdmin();
      allow create: if true; // Allow public creation from checkout simulation
      allow update, delete: if isAdmin();
    }

    // Verification Docs (KYB)
    match /verification_docs/{doc} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    // Limit Escalation Requests
    match /limit_requests/{request} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    // Sales Inquiries
    match /inquiries/{inquiry} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // Events and Logs (Global audit feed for mesh nodes)
    match /events/{event} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // Civic Plane
    match /civic/emergencies/active/{emergency} {
      allow read, write: if isAuthenticated();
    }
    
    // Readiness checks
    match /readiness/{checkId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
