
{
  "entities": {
    "TrustProfile": {
      "title": "Continuous Trust Profile",
      "description": "Dynamic identity and behavioral trust assessment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "entityId": { "type": "string" },
        "trustScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "riskDimensions": {
          "type": "object",
          "properties": {
            "identity": { "type": "number" },
            "financial": { "type": "number" },
            "network": { "type": "number" },
            "regulatory": { "type": "number" }
          }
        },
        "authorizationTier": { "type": "string", "enum": ["full", "limited", "manual_review", "hard_block"] },
        "lastEvaluated": { "type": "string", "format": "date-time" }
      }
    },
    "WalletBinding": {
      "title": "Cryptographic Identity Binding",
      "description": "Verification of wallet ownership bound to a UBO.",
      "type": "object",
      "properties": {
        "walletAddress": { "type": "string" },
        "ownerId": { "type": "string" },
        "proofHash": { "type": "string" },
        "status": { "type": "string", "enum": ["bound", "pending_proof", "rejected", "revoked"] },
        "reputationScore": { "type": "number" }
      }
    },
    "TrustAuditLog": {
      "title": "Trust Event Ledger",
      "description": "Immutable log of changes to trust scores and tiers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "trigger": { "type": "string" },
        "beforeScore": { "type": "number" },
        "afterScore": { "type": "number" },
        "reason": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/trust/profiles/{profileId}": { "schema": "TrustProfile", "description": "Continuous Trust Assessment." },
    "/trust/bindings/{bindingId}": { "schema": "WalletBinding", "description": "Identity-bound assets." },
    "/trust/audit_logs/{logId}": { "schema": "TrustAuditLog", "description": "Immutable Trust Ledger." }
  }
}
