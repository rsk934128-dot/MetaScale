
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended identity data for Sovereign OS citizens.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "mobile": { "type": "string" },
        "photoURL": { "type": "string" },
        "kernelId": { "type": "string" },
        "teamId": { "type": "string" },
        "accountNumber": { "type": "string" },
        "balance": { "type": "number" },
        "role": { "type": "string", "enum": ["ADMIN", "OPERATOR", "CITIZEN"] },
        "plan": { "type": "string", "enum": ["FREE", "PRO", "ENTERPRISE"] },
        "verificationStatus": { "type": "string", "enum": ["UNVERIFIED", "PENDING", "VERIFIED", "FLAGGED"] },
        "trustScore": { "type": "number" },
        "telegramChatId": { "type": "string" },
        "telegramLinked": { "type": "boolean" },
        "createdAt": { "type": "object" }
      },
      "required": ["uid", "email", "kernelId", "accountNumber", "teamId"]
    },
    "InboundPayment": {
      "title": "Inbound Payment Ledger",
      "description": "Normalized ledger for all incoming deposits and settlements.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unified internal payment ID." },
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "externalTxnId": { "type": "string" },
        "provider": { "type": "string", "enum": ["STRIPE", "BKASH", "BINANCE_PAY"] },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["CREATED", "USER_PAYING", "PAID", "CREDITED", "FAILED", "EXPIRED"] },
        "eventTime": { "type": "number" },
        "metadata": { "type": "object" }
      },
      "required": ["id", "orderId", "userId", "provider", "status"]
    },
    "VerificationDoc": {
      "title": "Identity Verification Document",
      "description": "Regulatory documents submitted for Stablecoin CIP compliance.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "type": { "type": "string", "enum": ["NID", "TIN", "PASSPORT"] },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "submittedAt": { "type": "number" },
        "metadata": { "type": "object" }
      }
    },
    "UBILEvent": {
      "title": "UBIL Webhook Event",
      "description": "A secure banking event received via UBIL Webhook node.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "senderBank": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "type", "status", "timestamp"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Extended user profile information." },
    "/payments/{paymentId}": { "schema": "InboundPayment", "description": "Central ledger for all incoming payments." },
    "/users/{userId}/payments/{paymentId}": { "schema": "InboundPayment", "description": "User specific payment history." },
    "/ubil_events/{eventId}": { "schema": "UBILEvent", "description": "Registry of all NoorNexus UBIL incoming events." },
    "/verification_docs/{docId}": { "schema": "VerificationDoc", "description": "User submitted verification documents." }
  }
}
