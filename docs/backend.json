
{
  "entities": {
    "Campaign": {
      "title": "Campaign",
      "description": "Cross-platform marketing campaign.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "platform": { "type": "string", "enum": ["meta", "google", "tiktok", "linkedin"] },
        "status": { "type": "string", "enum": ["active", "paused", "archived", "scheduled"] },
        "objective": { "type": "string" },
        "totalBudget": { "type": "number" },
        "spent": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "clientId": { "type": "string" }
      },
      "required": ["name", "platform", "status"]
    },
    "Recommendation": {
      "title": "AI Recommendation",
      "description": "AI-generated optimization insight.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["budget", "targeting", "creative", "scaling"] },
        "priority": { "type": "string", "enum": ["high", "medium", "low"] },
        "description": { "type": "string" },
        "impact": { "type": "string" },
        "targetId": { "type": "string" },
        "isApplied": { "type": "boolean" }
      }
    },
    "Client": {
      "title": "Agency Client",
      "description": "External client account for Agency Mode.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "company": { "type": "string" },
        "email": { "type": "string" },
        "logoUrl": { "type": "string" }
      }
    },
    "Notification": {
      "title": "System Alert",
      "description": "Real-time alerts for campaign anomalies.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "severity": { "type": "string", "enum": ["info", "warning", "critical"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" }
      }
    },
    "Asset": {
      "title": "Creative Asset",
      "description": "Marketing asset stored in Google Drive or system storage.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "mimeType": { "type": "string" },
        "driveFileId": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "clientId": { "type": "string" },
        "syncedAt": { "type": "string", "format": "date-time" },
        "size": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/campaigns/{campaignId}": {
      "schema": "Campaign",
      "description": "Global campaigns across platforms."
    },
    "/recommendations": {
      "schema": "Recommendation",
      "description": "AI-driven optimization pool."
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Agency clients."
    },
    "/notifications": {
      "schema": "Notification",
      "description": "System-wide alerts."
    },
    "/assets/{assetId}": {
      "schema": "Asset",
      "description": "Creative library assets synced from Google Drive."
    }
  }
}
