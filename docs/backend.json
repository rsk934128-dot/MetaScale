
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended identity data for Sovereign OS citizens.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "mobile": { "type": "string" },
        "photoURL": { "type": "string", "description": "URL to the citizen's profile image." },
        "kernelId": { "type": "string" },
        "teamId": { "type": "string", "description": "The unique identifier of the team/organization the user belongs to." },
        "accountNumber": { "type": "string", "description": "Unique 12-digit mesh account number." },
        "balance": { "type": "number", "description": "Current liquid assets in the system." },
        "role": { "type": "string", "enum": ["ADMIN", "OPERATOR", "CITIZEN"] },
        "plan": { "type": "string", "enum": ["FREE", "PRO", "ENTERPRISE"], "default": "FREE" },
        "verificationStatus": { "type": "string", "enum": ["UNVERIFIED", "PENDING", "VERIFIED", "FLAGGED"] },
        "trustScore": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "kernelId", "accountNumber", "teamId"]
    },
    "UBILEvent": {
      "title": "UBIL Webhook Event",
      "description": "A secure banking event received via UBIL Webhook node.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["TXN_SUCCESS", "BAL_UPDATE", "AUTH_FAILED"] },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "senderBank": { "type": "string" },
        "accountNumber": { "type": "string" },
        "senderName": { "type": "string" },
        "status": { "type": "string", "enum": ["SUCCESS", "BLOCKED"] },
        "signatureStatus": { "type": "string", "enum": ["VALID", "INVALID"] },
        "timestamp": { "type": "number" },
        "payload": { "type": "object" }
      },
      "required": ["id", "type", "status", "timestamp"]
    },
    "VirtualCard": {
      "title": "Fusion Virtual Card",
      "description": "Company-issued virtual Mastercard/Visa for citizens.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "cardNumber": { "type": "string", "description": "Masked card number (e.g. 5412 **** **** 1234)" },
        "expiry": { "type": "string" },
        "brand": { "type": "string", "enum": ["MASTERCARD", "VISA"] },
        "balance": { "type": "number" },
        "status": { "type": "string", "enum": ["ACTIVE", "FROZEN", "TERMINATED"] },
        "createdAt": { "type": "number" }
      }
    },
    "SalesInquiry": {
      "title": "Institutional Sales Inquiry",
      "description": "Enterprise-tier intake data for global settlement nodes.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "companyName": { "type": "string" },
        "estimatedMonthlyVolume": { "type": "string" },
        "useCase": { "type": "string" },
        "status": { "type": "string", "enum": ["NEW", "REVIEWING", "CONTACTED", "CLOSED"] },
        "timestamp": { "type": "number" }
      },
      "required": ["userId", "companyName", "estimatedMonthlyVolume"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Extended user profile information." },
    "/users/{userId}/cards": { "schema": "VirtualCard", "description": "Issued virtual cards for the user." },
    "/ubil_events": { "schema": "UBILEvent", "description": "Registry of all NoorNexus UBIL incoming events." },
    "/events": { "schema": "KernelEvent", "description": "Persistent log of all kernel events." }
  }
}
