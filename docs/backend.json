
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended identity data for Sovereign OS citizens.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "mobile": { "type": "string" },
        "kernelId": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "OPERATOR", "CITIZEN"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "kernelId"]
    },
    "SystemControlState": {
      "title": "System Control State",
      "description": "Current operational mode and priority settings for the Sovereign OS.",
      "type": "object",
      "properties": {
        "currentMode": { "type": "string", "enum": ["NORMAL", "EMERGENCY", "LOCKDOWN", "DISASTER"] },
        "activePriority": { "type": "string", "enum": ["EFFICIENCY", "SECURITY", "SURVIVAL"] },
        "lastModeChange": { "type": "string", "format": "date-time" }
      }
    },
    "KernelEvent": {
      "title": "Kernel Event Log",
      "description": "A persistent record of a deterministic event processed by the kernel.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "plane": { "type": "string", "enum": ["CIVIC", "FINANCE", "SECURITY", "INFRA", "COMMUNICATION"] },
        "type": { "type": "string" },
        "priority": { "type": "number" },
        "timestamp": { "type": "number" },
        "status": { "type": "string" },
        "payload": { "type": "object" }
      },
      "required": ["id", "plane", "type", "priority", "timestamp", "status"]
    },
    "BankAccount": {
      "title": "Simulated Bank Account",
      "description": "Mock account data for Open Banking testing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bankName": { "type": "string" },
        "accountNumber": { "type": "string" },
        "balance": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["CONNECTED", "DISCONNECTED"] }
      }
    },
    "BankTransaction": {
      "title": "Simulated Transaction",
      "description": "Mock transaction record for Open Banking AIS tests.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "accountId": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "CommunicationMessage": {
      "title": "Communication Log",
      "description": "Metadata and intelligence derived from intercepted or synced communications.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "source": { "type": "string", "enum": ["GMAIL", "INTERNAL", "SIGNAL"] },
        "sender": { "type": "string" },
        "subject": { "type": "string" },
        "intelligenceRating": { "type": "number" },
        "processedAt": { "type": "string", "format": "date-time" }
      }
    },
    "CivicEmergency": {
      "title": "Civic Emergency Event",
      "description": "Real-time incident data for flood, SOS, or dispatch events.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["FLOOD", "SOS", "FIRE", "CIVIL_UNREST"] },
        "severity": { "type": "number", "minimum": 1, "maximum": 5 },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["DETECTED", "DISPATCHED", "RESOLVED"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Extended user profile information." },
    "/system/control": { "schema": "SystemControlState", "description": "Global OS mode state." },
    "/system/events": { "schema": "KernelEvent", "description": "Persistent log of all kernel events." },
    "/civic/emergencies": { "schema": "CivicEmergency", "description": "Active SOS and disaster events." },
    "/finance/accounts": { "schema": "BankAccount", "description": "Connected mock bank accounts." }
  }
}
