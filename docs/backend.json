
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended identity data for Sovereign OS citizens.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "mobile": { "type": "string" },
        "photoURL": { "type": "string", "description": "URL to the citizen's profile image." },
        "kernelId": { "type": "string" },
        "accountNumber": { "type": "string", "description": "Unique 12-digit mesh account number." },
        "balance": { "type": "number", "description": "Current liquid assets in the system." },
        "role": { "type": "string", "enum": ["ADMIN", "OPERATOR", "CITIZEN"] },
        "verificationStatus": { "type": "string", "enum": ["UNVERIFIED", "PENDING", "VERIFIED", "FLAGGED"] },
        "trustScore": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "kernelId", "accountNumber"]
    },
    "LibraryAsset": {
      "title": "Library Asset",
      "description": "A media asset stored in the citizen's personal library.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "thumbnail": { "type": "string" },
        "mimeType": { "type": "string" },
        "source": { "type": "string", "enum": ["GOOGLE_DRIVE", "LOCAL_UPLOAD"] },
        "createdAt": { "type": "number" }
      }
    },
    "PaymentLink": {
      "title": "Sovereign Payment Link",
      "description": "A cryptographically signed link for requesting funds.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "PAID", "EXPIRED"] },
        "paymentMethod": { "type": "string", "description": "Method used for the settlement (Visa, Nagad, etc.)" },
        "seal": { "type": "string" },
        "createdAt": { "type": "number" },
        "paidAt": { "type": "number" }
      }
    },
    "TINCertificate": {
      "title": "TIN Certificate",
      "description": "Taxpayer Identification Number data for civic compliance.",
      "type": "object",
      "properties": {
        "tin": { "type": "string" },
        "name": { "type": "string" },
        "fatherName": { "type": "string" },
        "address": { "type": "string" },
        "issueDate": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "NIDCertificate": {
      "title": "National ID Certificate",
      "description": "Government-issued identity data for citizenship binding.",
      "type": "object",
      "properties": {
        "nid": { "type": "string" },
        "name": { "type": "string" },
        "father": { "type": "string" },
        "mother": { "type": "string" },
        "dob": { "type": "string" },
        "issueDate": { "type": "string" }
      }
    },
    "VerificationDocument": {
      "title": "Verification Document",
      "description": "A document submitted for identity or compliance verification.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "type": { "type": "string", "enum": ["TIN", "NID", "PASSPORT"] },
        "fileUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "metadata": { "type": "object" },
        "submittedAt": { "type": "number" }
      }
    },
    "MediaAsset": {
      "title": "Media Asset",
      "description": "Metadata for a media stream or file within the mesh.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "thumbnail": { "type": "string" },
        "duration": { "type": "number" },
        "source": { "type": "string", "enum": ["MESH_LOCAL", "YOUTUBE_PIS", "STREAM_CORRIDOR"] }
      }
    },
    "MediaTask": {
      "title": "Media Extraction Task",
      "description": "A background task for offline synchronization of media assets.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "assetId": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "EXTRACTING", "COMPLETED", "FAILED"] },
        "progress": { "type": "number" },
        "bitrate": { "type": "string" }
      }
    },
    "SystemControlState": {
      "title": "System Control State",
      "description": "Current operational mode and priority settings for the Sovereign OS.",
      "type": "object",
      "properties": {
        "currentMode": { "type": "string", "enum": ["NORMAL", "EMERGENCY", "LOCKDOWN", "DISASTER"] },
        "activePriority": { "type": "string", "enum": ["EFFICIENCY", "SECURITY", "SURVIVAL"] },
        "lastModeChange": { "type": "string", "format": "date-time" }
      }
    },
    "KernelEvent": {
      "title": "Kernel Event Log",
      "description": "A persistent record of a deterministic event processed by the kernel.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "plane": { "type": "string", "enum": ["CIVIC", "FINANCE", "SECURITY", "INFRA", "COMMUNICATION", "MEDIA"] },
        "type": { "type": "string" },
        "priority": { "type": "number" },
        "timestamp": { "type": "number" },
        "status": { "type": "string" },
        "payload": { "type": "object" }
      },
      "required": ["id", "plane", "type", "priority", "timestamp", "status"]
    },
    "Notification": {
      "title": "System Notification",
      "description": "A real-time alert delivered to a citizen node.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["INFO", "WARNING", "CRITICAL", "DIRECTIVE"] },
        "read": { "type": "boolean" },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "title", "message", "type", "read", "timestamp"]
    },
    "BankAccount": {
      "title": "Simulated Bank Account",
      "description": "Mock account data for Open Banking testing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bankName": { "type": "string" },
        "accountNumber": { "type": "string" },
        "balance": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["CONNECTED", "DISCONNECTED"] }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Extended user profile information." },
    "/users/{userId}/notifications": { "schema": "Notification", "description": "User specific real-time alerts." },
    "/users/{userId}/payment_links": { "schema": "PaymentLink", "description": "User generated payment request links." },
    "/users/{userId}/media_tasks": { "schema": "MediaTask", "description": "User specific media extraction tasks." },
    "/users/{userId}/assets": { "schema": "LibraryAsset", "description": "Citizen's media library assets." },
    "/verification_docs/{docId}": { "schema": "VerificationDocument", "description": "Pending compliance documents." },
    "/system/control": { "schema": "SystemControlState", "description": "Global OS mode state." },
    "/events": { "schema": "KernelEvent", "description": "Persistent log of all kernel events." },
    "/payment_links/{linkId}": { "schema": "PaymentLink", "description": "Public registry of payment links." }
  }
}
