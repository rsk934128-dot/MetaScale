
{
  "entities": {
    "SystemControlState": {
      "title": "System Control State",
      "description": "Current operational mode and priority settings for the Sovereign OS.",
      "type": "object",
      "properties": {
        "currentMode": { "type": "string", "enum": ["NORMAL", "EMERGENCY", "LOCKDOWN", "DISASTER"] },
        "activePriority": { "type": "string", "enum": ["EFFICIENCY", "SECURITY", "SURVIVAL"] },
        "lastModeChange": { "type": "string", "format": "date-time" }
      }
    },
    "KernelEvent": {
      "title": "Kernel Event Log",
      "description": "A persistent record of a deterministic event processed by the kernel.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "plane": { "type": "string", "enum": ["CIVIC", "FINANCE", "SECURITY", "INFRA"] },
        "type": { "type": "string" },
        "priority": { "type": "number" },
        "timestamp": { "type": "number" },
        "status": { "type": "string" },
        "payload": { "type": "object" }
      },
      "required": ["id", "plane", "type", "priority", "timestamp", "status"]
    },
    "CivicEmergency": {
      "title": "Civic Emergency Event",
      "description": "Real-time incident data for flood, SOS, or dispatch events.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["FLOOD", "SOS", "FIRE", "CIVIL_UNREST"] },
        "severity": { "type": "number", "minimum": 1, "maximum": 5 },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["DETECTED", "DISPATCHED", "RESOLVED"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "NetworkNode": {
      "title": "Infrastructure Mesh Node",
      "description": "Data for one of the 42 distributed nodes in the anycast mesh.",
      "type": "object",
      "properties": {
        "nodeId": { "type": "string" },
        "status": { "type": "string", "enum": ["ONLINE", "OFFLINE", "DEGRADED", "ISOLATED"] },
        "load": { "type": "number" },
        "latency": { "type": "number" },
        "region": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/system/control": { "schema": "SystemControlState", "description": "Global OS mode state." },
    "/system/events": { "schema": "KernelEvent", "description": "Persistent log of all kernel events." },
    "/civic/emergencies": { "schema": "CivicEmergency", "description": "Active SOS and disaster events." },
    "/infrastructure/nodes": { "schema": "NetworkNode", "description": "Mesh network status logs." }
  }
}
