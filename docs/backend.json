
{
  "entities": {
    "Campaign": {
      "title": "Campaign",
      "description": "Cross-platform marketing campaign.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "platform": { "type": "string", "enum": ["meta", "google", "tiktok", "linkedin"] },
        "status": { "type": "string", "enum": ["active", "paused", "archived", "scheduled"] },
        "objective": { "type": "string" },
        "totalBudget": { "type": "number" },
        "spent": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "clientId": { "type": "string" }
      },
      "required": ["name", "platform", "status"]
    },
    "Agent": {
      "title": "Autonomous Agent",
      "description": "Specialized AI agent (Marketing, Sales, Research, Forecasting).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["marketing", "sales", "analytics", "research", "forecasting", "executive", "finance", "operations", "risk"] },
        "status": { "type": "string", "enum": ["idle", "executing", "completed", "error"] },
        "lastRun": { "type": "string", "format": "date-time" },
        "performanceScore": { "type": "number" }
      }
    },
    "Customer": {
      "title": "Enterprise Customer",
      "description": "Unified 360 customer profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "ltv": { "type": "number" },
        "cac": { "type": "number" },
        "segment": { "type": "string" },
        "churnRisk": { "type": "number" }
      }
    },
    "Finance": {
      "title": "Financial Record",
      "description": "Corporate financial data for Sovereign SEIP.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string", "enum": ["revenue", "expense", "opex", "capex"] },
        "actual": { "type": "number" },
        "projected": { "type": "number" },
        "variance": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "OperationalKPI": {
      "title": "Operational Metric",
      "description": "Real-time process performance indicator.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "value": { "type": "number" },
        "target": { "type": "number" },
        "status": { "type": "string", "enum": ["optimal", "warning", "critical"] }
      }
    },
    "Risk": {
      "title": "Enterprise Risk",
      "description": "Strategic, financial, or operational risks.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string", "enum": ["strategic", "financial", "operational", "compliance"] },
        "impact": { "type": "number" },
        "probability": { "type": "number" },
        "mitigationPlan": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/campaigns/{campaignId}": { "schema": "Campaign", "description": "Global campaigns." },
    "/agents/{agentId}": { "schema": "Agent", "description": "Sovereign AI Council." },
    "/customers/{customerId}": { "schema": "Customer", "description": "Customer Hub." },
    "/finance/{financeId}": { "schema": "Finance", "description": "Financial records." },
    "/operations/{opId}": { "schema": "OperationalKPI", "description": "Operational Twin metrics." },
    "/risks/{riskId}": { "schema": "Risk", "description": "Risk Observatory." }
  }
}
