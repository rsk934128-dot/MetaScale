
{
  "entities": {
    "Campaign": {
      "title": "Campaign",
      "description": "Cross-platform marketing campaign.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "platform": { "type": "string", "enum": ["meta", "google", "tiktok", "linkedin"] },
        "status": { "type": "string", "enum": ["active", "paused", "archived", "scheduled"] },
        "objective": { "type": "string" },
        "totalBudget": { "type": "number" },
        "spent": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "clientId": { "type": "string" }
      },
      "required": ["name", "platform", "status"]
    },
    "LegalEntity": {
      "title": "Legal Entity (Layer 1)",
      "description": "Enterprise KYB and registration details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyName": { "type": "string" },
        "registrationNumber": { "type": "string" },
        "jurisdiction": { "type": "string" },
        "status": { "type": "string", "enum": ["verified", "pending", "action-needed", "expired"] },
        "progress": { "type": "number" }
      }
    },
    "UBO": {
      "title": "Beneficial Owner (Layer 2)",
      "description": "Individual identity verification data.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string", "enum": ["verified", "pending", "rejected"] },
        "identityProvider": { "type": "string" }
      }
    },
    "SettlementConfig": {
      "title": "Treasury & Settlement (Layer 3)",
      "description": "Financial disbursement configuration and governance.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "walletAddress": { "type": "string" },
        "network": { "type": "string" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "gated", "restricted"] },
        "proofOfOwnership": { "type": "boolean" }
      }
    },
    "AuditLog": {
      "title": "Governance Audit Trail",
      "description": "Immutable ledger of compliance and treasury events.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "actor": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "impact": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/compliance/entities/{entityId}": { "schema": "LegalEntity", "description": "L1 Legal Entities." },
    "/compliance/ubos/{uboId}": { "schema": "UBO", "description": "L2 Beneficial Owners." },
    "/compliance/settlements/{settleId}": { "schema": "SettlementConfig", "description": "L3 Settlement Governance." },
    "/compliance/audit_logs/{logId}": { "schema": "AuditLog", "description": "Immutable Governance Trail." }
  }
}
