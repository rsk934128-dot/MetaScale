{
  "entities": {
    "Campaign": {
      "title": "Campaign",
      "description": "Cross-platform marketing campaign.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "platform": { "type": "string", "enum": ["meta", "google", "tiktok", "linkedin"] },
        "status": { "type": "string", "enum": ["active", "paused", "archived", "scheduled"] },
        "objective": { "type": "string" },
        "totalBudget": { "type": "number" },
        "spent": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "clientId": { "type": "string" }
      },
      "required": ["name", "platform", "status"]
    },
    "Agent": {
      "title": "Autonomous Agent",
      "description": "Specialized AI agent (Marketing, Sales, Research, Forecasting).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["marketing", "sales", "analytics", "research", "forecasting", "executive"] },
        "status": { "type": "string", "enum": ["idle", "executing", "completed", "error"] },
        "lastRun": { "type": "string", "format": "date-time" },
        "performanceScore": { "type": "number" }
      }
    },
    "Customer": {
      "title": "Enterprise Customer",
      "description": "Unified 360 customer profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "ltv": { "type": "number", "description": "Lifetime Value" },
        "cac": { "type": "number", "description": "Customer Acquisition Cost" },
        "segment": { "type": "string" },
        "churnRisk": { "type": "number" },
        "lastInteraction": { "type": "string", "format": "date-time" }
      }
    },
    "Sale": {
      "title": "Revenue Transaction",
      "description": "Sales data for revenue operations.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "customerId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "closed", "lost"] },
        "source": { "type": "string" }
      }
    },
    "Objective": {
      "title": "Corporate Objective",
      "description": "Strategic goal for business growth.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "progress": { "type": "number" },
        "targetValue": { "type": "number" },
        "deadline": { "type": "string", "format": "date-time" }
      }
    },
    "Asset": {
      "title": "Creative Asset",
      "description": "Marketing asset synced from Google Drive.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "driveFileId": { "type": "string" },
        "clientId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/campaigns/{campaignId}": { "schema": "Campaign", "description": "Global campaigns." },
    "/agents/{agentId}": { "schema": "Agent", "description": "Specialized enterprise agents." },
    "/customers/{customerId}": { "schema": "Customer", "description": "360 Customer Hub." },
    "/sales/{saleId}": { "schema": "Sale", "description": "Revenue stream logs." },
    "/objectives/{objectiveId}": { "schema": "Objective", "description": "Strategic board objectives." },
    "/assets/{assetId}": { "schema": "Asset", "description": "Creative library." }
  }
}