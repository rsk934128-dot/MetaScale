
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended identity data for Sovereign OS citizens.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "mobile": { "type": "string" },
        "photoURL": { "type": "string" },
        "kernelId": { "type": "string" },
        "teamId": { "type": "string" },
        "accountNumber": { "type": "string" },
        "balance": { "type": "number" },
        "role": { "type": "string", "enum": ["ADMIN", "OPERATOR", "CITIZEN"] },
        "plan": { "type": "string", "enum": ["FREE", "PRO", "ENTERPRISE"] },
        "verificationStatus": { "type": "string", "enum": ["UNVERIFIED", "PENDING", "VERIFIED", "FLAGGED"] },
        "trustScore": { "type": "number" },
        "createdAt": { "type": "object" }
      },
      "required": ["uid", "email", "kernelId", "accountNumber", "teamId"]
    },
    "UBILEvent": {
      "title": "UBIL Webhook Event",
      "description": "A secure banking event received via UBIL Webhook node.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "senderBank": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "type", "status", "timestamp"]
    },
    "VirtualCard": {
      "title": "Fusion Virtual Card",
      "description": "Company-issued virtual card.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "cardNumber": { "type": "string" },
        "expiry": { "type": "string" },
        "brand": { "type": "string" },
        "balance": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "SovereignEvent": {
      "title": "Sovereign Event",
      "description": "Deterministic kernel event log.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "plane": { "type": "string", "enum": ["CIVIC", "FINANCE", "SECURITY", "INFRA"] },
        "type": { "type": "string" },
        "priority": { "type": "number" },
        "timestamp": { "type": "number" },
        "payload": { "type": "object" },
        "status": { "type": "string", "enum": ["QUEUED", "PROCESSING", "COMPLETED", "FAILED", "REJECTED", "ROLLED_BACK"] }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Extended user profile information." },
    "/users/{userId}/cards/{cardId}": { "schema": "VirtualCard", "description": "Issued virtual cards for the user." },
    "/users/{userId}/watchlist/{tickerId}": { "schema": "WatchlistItem", "description": "Users financial watchlist." },
    "/users/{userId}/assets/{assetId}": { "schema": "Asset", "description": "Users private library assets." },
    "/users/{userId}/notifications/{notifId}": { "schema": "Notification", "description": "Users system notifications." },
    "/users/{userId}/payment_links/{linkId}": { "schema": "PaymentLink", "description": "Users private payment links." },
    "/payment_links/{sealId}": { "schema": "PaymentLink", "description": "Public checkout links." },
    "/ubil_events/{eventId}": { "schema": "UBILEvent", "description": "Registry of all NoorNexus UBIL incoming events." },
    "/events/{eventId}": { "schema": "SovereignEvent", "description": "Persistent log of all kernel events." },
    "/verification_docs/{docId}": { "schema": "VerificationDoc", "description": "User submitted verification documents." }
  }
}
