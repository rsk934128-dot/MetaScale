
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended identity data for Sovereign OS citizens.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "mobile": { "type": "string" },
        "photoURL": { "type": "string" },
        "kernelId": { "type": "string" },
        "teamId": { "type": "string" },
        "accountNumber": { "type": "string" },
        "balance": { "type": "number" },
        "role": { "type": "string", "enum": ["ADMIN", "OPERATOR", "CITIZEN"] },
        "plan": { "type": "string", "enum": ["FREE", "PRO", "ENTERPRISE"] },
        "verificationStatus": { "type": "string", "enum": ["UNVERIFIED", "PENDING", "VERIFIED", "FLAGGED"] },
        "trustScore": { "type": "number" },
        "telegramChatId": { "type": "string" },
        "telegramLinked": { "type": "boolean" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["uid", "email", "kernelId", "accountNumber", "teamId"]
    },
    "InboundPayment": {
      "title": "Inbound Payment Ledger",
      "description": "Normalized ledger for all incoming deposits and settlements with reconciliation fields.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "externalTxnId": { "type": "string" },
        "provider": { "type": "string", "enum": ["STRIPE", "BKASH", "BINANCE_PAY"] },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string" },
        "isCredited": { "type": "boolean" },
        "creditOperationId": { "type": "string" },
        "reconciliationStatus": { "type": "string", "enum": ["NOT_REQUIRED", "PENDING", "MATCHED", "MISMATCHED"] },
        "anomalyFlags": { "type": "array", "items": { "type": "string" } },
        "eventTime": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "statusHistory": { "type": "array" }
      },
      "required": ["id", "userId", "provider", "status", "isCredited"]
    },
    "VerificationDoc": {
      "title": "Identity Verification Document",
      "description": "Regulatory documents submitted for Stablecoin CIP compliance.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "type": { "type": "string", "enum": ["NID", "TIN", "PASSPORT"] },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "submittedAt": { "type": "number" },
        "metadata": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Extended user profile information." },
    "/payments/{paymentId}": { "schema": "InboundPayment", "description": "Central ledger for all incoming payments." },
    "/verification_docs/{docId}": { "schema": "VerificationDoc", "description": "User submitted verification documents." }
  }
}
