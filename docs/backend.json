
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended identity data for Sovereign OS citizens.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "kernelId": { "type": "string" },
        "accountNumber": { "type": "string" },
        "balance": { "type": "number" },
        "role": { "type": "string", "enum": ["ADMIN", "OPERATOR", "CITIZEN"] },
        "plan": { "type": "string", "enum": ["FREE", "PRO", "ENTERPRISE"] },
        "verificationStatus": { "type": "string", "enum": ["UNVERIFIED", "PENDING", "VERIFIED", "FLAGGED"] },
        "trustScore": { "type": "number" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      }
    },
    "InboundPayment": {
      "title": "Inbound Payment Ledger",
      "description": "Normalized ledger with Phase 2.7 indexing fields.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "status": { "type": "string" },
        "isCredited": { "type": "boolean" },
        "credited": { "type": "boolean", "description": "Derived field for fast indexing." },
        "manualReviewRequired": { "type": "boolean" },
        "settlementBucket": { "type": "string", "enum": ["DONE", "READY_FOR_REPLAY", "WAITING_BACKOFF", "FATAL"] },
        "replayCount": { "type": "number" },
        "nextReplayAttemptAt": { "type": "number" },
        "anomalyFlags": { "type": "array" },
        "eventTime": { "type": "number" },
        "updatedAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile" },
    "/payments/{paymentId}": { "schema": "InboundPayment" }
  },
  "indexes": {
    "required_composite": [
      { "collection": "payments", "fields": ["settlementBucket", "updatedAt desc"] },
      { "collection": "payments", "fields": ["manualReviewRequired", "updatedAt desc"] },
      { "collection": "verification_docs", "fields": ["submittedAt desc"] }
    ]
  }
}
